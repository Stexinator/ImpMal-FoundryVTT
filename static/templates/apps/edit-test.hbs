    <div>
        <div class="form-group">
            <label>{{localize "IMPMAL.Roll"}}</label>
            <div class="form-fields">
                <input type="number" name="roll" value="{{result.roll}}">
            </div>
        </div>

        <div class="form-group">
            <label>{{localize "IMPMAL.Target"}}</label>
            <div class="form-fields">
                <input type="number" name="target" value="{{result.target}}">
            </div>
        </div>

        <div class="form-group">
            <label>{{localize "IMPMAL.SL"}}</label>
            <div class="form-fields">
                <input type="number" name="SL" value="{{result.SL}}">
            </div>
        </div>

        
        <div class="form-group">
            <label>{{localize "IMPMAL.State"}}</label>
            <div class="form-fields">
                <select name="state">
                    {{selectOptions states selected=result.state localize=true}}
                </select>
            </div>
        </div>
    </div>